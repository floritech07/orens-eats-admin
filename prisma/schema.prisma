generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  CASHIER
}

model User {
  id              String           @id @default(cuid())
  email           String           @unique
  password        String
  name            String
  role            Role             @default(CASHIER)
  orders          Order[]          @relation("UserOrders")
  cashierProfiles CashierProfile[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model CashierProfile {
  id        String   @id @default(cuid())
  name      String
  pin       String   // 4-digit code
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  orders    Order[]  @relation("ProfileOrders")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id        String    @id @default(cuid())
  name      String
  emoji     String?
  items     Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id             String          @id @default(cuid())
  name           String
  description    String?
  price          Int
  emoji          String?
  stock          Int             @default(0)
  isAvailable    Boolean         @default(true)
  isDailySpecial Boolean         @default(false)
  categoryId     String
  category       Category        @relation(fields: [categoryId], references: [id])
  accompaniments Accompaniment[]
  orderItems     OrderItem[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Accompaniment {
  id        String   @id @default(cuid())
  label     String
  price     Int
  productId String
  product   Product  @relation(fields: [productId], references: [id])
}

model Order {
  id              String        @id @default(cuid())
  totalAmount     Int
  status          OrderStatus   @default(PENDING)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentRef      String?       @unique
  customerName    String?
  customerPhone   String?
  deliveryMode    String? // cafeteria or livraison
  location        String?
  items           OrderItem[]
  cashierId       String?
  cashier         User?           @relation("UserOrders", fields: [cashierId], references: [id])
  profileId       String?
  profile         CashierProfile? @relation("ProfileOrders", fields: [profileId], references: [id])
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model OrderItem {
  id             String  @id @default(cuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id])
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  quantity       Int
  price          Int
  accompLabel    String?
  accompPrice    Int?
}

enum OrderStatus {
  PENDING
  PROCESSING
  READY
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}
